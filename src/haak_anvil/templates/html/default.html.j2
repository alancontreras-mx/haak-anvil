<!doctype html>
<html lang="{{ engagement.language[:2] }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pentest Report — {{ engagement.client_name }} ({{ engagement.id }})</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif; }
    .finding { scroll-margin-top: 80px; }
    @media print {
      .no-print { display: none; }
      .finding { page-break-inside: avoid; }
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-900">

  <!-- Header bar -->
  <header class="bg-slate-900 text-white">
    <div class="max-w-5xl mx-auto px-6 py-8">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm uppercase tracking-widest text-slate-400">Haak Cybersecurity Consulting</p>
          <h1 class="text-3xl font-bold mt-1">Pentest Report</h1>
          <p class="mt-2 text-slate-300">{{ engagement.client_name }} · <span class="font-mono">{{ engagement.id }}</span></p>
        </div>
        <div class="text-right text-sm text-slate-400">
          <p>Generated {{ bundle.generated_at.strftime("%Y-%m-%d %H:%M UTC") }}</p>
          <p>{{ bundle.generator }} v{{ bundle.generator_version }}</p>
        </div>
      </div>
    </div>
  </header>

  <!-- Meta -->
  <section class="max-w-5xl mx-auto px-6 py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div><dt class="text-slate-500">Methodology</dt><dd class="font-semibold">{{ engagement.methodology }}</dd></div>
      <div><dt class="text-slate-500">Analyst</dt><dd class="font-semibold">{{ engagement.analyst }}</dd></div>
      <div><dt class="text-slate-500">Window</dt><dd class="font-semibold">{{ engagement.period_start or "—" }} → {{ engagement.period_end or "—" }}</dd></div>
      <div><dt class="text-slate-500">Language</dt><dd class="font-semibold">{{ engagement.language }}</dd></div>
    </div>
    <div class="mt-4">
      <dt class="text-slate-500 text-sm">Scope</dt>
      <dd class="mt-1">{{ engagement.scope }}</dd>
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-5xl mx-auto px-6 py-4">
    <h2 class="text-xl font-bold mb-4">Executive summary</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {% for sev in [Severity.CRITICAL, Severity.HIGH, Severity.MEDIUM, Severity.LOW, Severity.INFO] %}
      <div class="rounded-lg p-4 {{ sev | sev_class }}">
        <div class="text-3xl font-bold">{{ breakdown[sev.value] }}</div>
        <div class="text-sm uppercase tracking-wide">{{ sev.value }}</div>
      </div>
      {% endfor %}
    </div>
    <p class="mt-4 text-sm text-slate-600">
      {{ findings | length }} findings across {{ assets | length }} asset(s).
    </p>
  </section>

  <!-- Findings -->
  <section class="max-w-5xl mx-auto px-6 py-6">
    <h2 class="text-xl font-bold mb-4">Findings</h2>
    {% for f in findings %}
    <article id="{{ f.id }}" class="finding bg-white rounded-lg shadow-sm p-5 mb-4 border border-slate-200">
      <div class="flex items-center justify-between gap-3 mb-2 flex-wrap">
        <h3 class="text-lg font-semibold">{{ f.title }}</h3>
        <span class="px-2 py-1 rounded text-xs uppercase tracking-wide {{ f.severity | sev_class }}">
          {{ f.severity.value }}
        </span>
      </div>
      <div class="text-xs text-slate-500 mb-3 flex flex-wrap gap-x-4 gap-y-1">
        {% if f.asset %}<span><span class="font-semibold">Asset:</span> <code>{{ f.asset }}</code></span>{% endif %}
        {% if f.port %}<span><span class="font-semibold">Port:</span> {{ f.port }}/{{ f.protocol or "tcp" }}</span>{% endif %}
        {% if f.cvss %}<span><span class="font-semibold">CVSS {{ f.cvss.version }}:</span> {{ f.cvss.score }}</span>{% endif %}
        <span><span class="font-semibold">Tool:</span> <code>{{ f.tool }}</code></span>
        {% if f.plugin_id %}<span><span class="font-semibold">Plugin:</span> {{ f.plugin_id }}</span>{% endif %}
      </div>
      {% if f.description %}<p class="text-slate-800 whitespace-pre-wrap mb-3">{{ f.description }}</p>{% endif %}
      {% if f.impact %}
      <div class="mb-3">
        <h4 class="font-semibold text-sm uppercase text-slate-500">Impact</h4>
        <p class="whitespace-pre-wrap">{{ f.impact }}</p>
      </div>
      {% endif %}
      {% if f.remediation %}
      <div class="mb-3">
        <h4 class="font-semibold text-sm uppercase text-slate-500">Remediation</h4>
        <p class="whitespace-pre-wrap">{{ f.remediation }}</p>
      </div>
      {% endif %}
      {% if f.cve or f.cwe %}
      <div class="mb-3 text-sm">
        {% if f.cve %}<div><span class="font-semibold">CVE:</span> {{ f.cve | join(", ") }}</div>{% endif %}
        {% if f.cwe %}<div><span class="font-semibold">CWE:</span> {{ f.cwe | join(", ") }}</div>{% endif %}
      </div>
      {% endif %}
      {% if f.references %}
      <details class="mt-2">
        <summary class="cursor-pointer text-sm text-blue-600 hover:underline">References ({{ f.references | length }})</summary>
        <ul class="mt-2 ml-4 list-disc text-sm">
          {% for r in f.references %}<li><a class="text-blue-600 hover:underline break-all" href="{{ r }}">{{ r }}</a></li>{% endfor %}
        </ul>
      </details>
      {% endif %}
      {% if f.evidence %}
      <details class="mt-2">
        <summary class="cursor-pointer text-sm text-slate-600 hover:underline">Evidence</summary>
        <pre class="mt-2 p-3 bg-slate-100 rounded text-xs overflow-x-auto">{{ f.evidence }}</pre>
      </details>
      {% endif %}
    </article>
    {% endfor %}
  </section>

  <!-- Assets -->
  <section class="max-w-5xl mx-auto px-6 py-6">
    <h2 class="text-xl font-bold mb-4">Assets</h2>
    <div class="overflow-x-auto bg-white border border-slate-200 rounded-lg">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-100 text-slate-600 uppercase text-xs">
          <tr>
            <th class="text-left px-4 py-2">Address</th>
            <th class="text-left px-4 py-2">Hostname</th>
            <th class="text-left px-4 py-2">OS</th>
            <th class="text-right px-4 py-2">Open ports</th>
          </tr>
        </thead>
        <tbody>
          {% for a in assets %}
          <tr class="border-t border-slate-100">
            <td class="px-4 py-2 font-mono">{{ a.address }}</td>
            <td class="px-4 py-2">{{ a.hostname or "—" }}</td>
            <td class="px-4 py-2">{{ a.os or "—" }}</td>
            <td class="px-4 py-2 text-right">{{ a.open_port_count }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Footer -->
  <footer class="max-w-5xl mx-auto px-6 py-8 mt-8 border-t border-slate-200 text-center text-sm text-slate-500">
    <p>Generated by <strong>{{ bundle.generator }}</strong> v{{ bundle.generator_version }}</p>
    <p><a class="text-blue-600 hover:underline" href="https://haak.com.mx">Haak Cybersecurity Consulting</a> · {{ bundle.generated_at.year }}</p>
  </footer>

</body>
</html>
